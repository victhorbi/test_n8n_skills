# Credentials & endpoints (required at runtime)
GITHUB_TOKEN=
OPENROUTER_API_KEY=
# n8n chat webhook hosting the agent under test (ends in /chat)
N8N_AGENT_WEBHOOK_URL=https://vechain.app.n8n.cloud/webhook/<id>/chat

# Target (in CI these come from the GitHub context; set them for local runs)
OWNER=victhorbi
REPO=test_n8n_skills
AGENT_FOLDER=agents/akinator
BRANCH=
PR_NUMBER=

# Eval parameters
MAX_ITERATIONS=40
MIN_SUCCESS_RATE=50
MAX_AVG_ITERATIONS=30
USER_MODEL=deepseek/deepseek-v4-flash

# Behaviour
COMMIT=true
DRY_RUN=false
FAIL_ON_REGRESSION=false
CONCURRENCY=1
